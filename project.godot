; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the format is simple enough to edit manually.
;
; [section] ; section goes in []
; [section.subsection]
; key=value ; assign values

config_version=5

[application]

config/name="달님이 의사놀이"
config/description="달님이와 함께하는 즐거운 의사놀이"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://assets/ui/icon.png"

[autoload]

GameManager="*res://autoload/GameManager.gd"
SoundManager="*res://autoload/SoundManager.gd"
SaveManager="*res://autoload/SaveManager.gd"
SceneTransition="*res://autoload/SceneTransition.gd"
UIAnimations="*res://autoload/UIAnimations.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
