[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/patient_select.gd" id="1"]

[node name="PatientSelect" type="Node2D"]
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
offset_right = 1080.0
offset_bottom = 1920.0
color = Color(0.95, 0.92, 1.0)

[node name="Title" type="Label" parent="."]
offset_left = 100.0
offset_top = 80.0
offset_right = 980.0
offset_bottom = 200.0
theme_override_font_sizes/font_size = 64
horizontal_alignment = 1
text = "누가 아픈가요? 🤒"
theme_override_colors/font_color = Color(0.4, 0.2, 0.7)

[node name="PatientGrid" type="GridContainer" parent="."]
offset_left = 80.0
offset_top = 260.0
offset_right = 1000.0
offset_bottom = 1700.0
columns = 2

[node name="DaltooBt" type="Button" parent="PatientGrid"]
custom_minimum_size = Vector2(440, 640)
theme_override_font_sizes/font_size = 44
text = "🐰\n달토끼\n\n(흰 토끼)"
[connection signal="pressed" from="PatientGrid/DaltooBt" to="." method="_on_patient_pressed" binds=["daltooki"]]

[node name="DalkongiBt" type="Button" parent="PatientGrid"]
custom_minimum_size = Vector2(440, 640)
theme_override_font_sizes/font_size = 44
text = "👶\n달콩이\n\n(달님이 동생)"
[connection signal="pressed" from="PatientGrid/DalkongiBt" to="." method="_on_patient_pressed" binds=["dalkongi"]]

[node name="SunnyBt" type="Button" parent="PatientGrid"]
custom_minimum_size = Vector2(440, 640)
theme_override_font_sizes/font_size = 44
text = "☀️\n써니\n\n(달님이 친구)"
[connection signal="pressed" from="PatientGrid/SunnyBt" to="." method="_on_patient_pressed" binds=["sunny"]]

[node name="ByeoliBt" type="Button" parent="PatientGrid"]
custom_minimum_size = Vector2(440, 640)
theme_override_font_sizes/font_size = 44
text = "⭐\n별이\n\n(달님이 친구)"
[connection signal="pressed" from="PatientGrid/ByeoliBt" to="." method="_on_patient_pressed" binds=["byeoli"]]

[node name="BackButton" type="Button" parent="."]
offset_left = 40.0
offset_top = 1780.0
offset_right = 280.0
offset_bottom = 1880.0
theme_override_font_sizes/font_size = 40
text = "← 뒤로"
[connection signal="pressed" from="BackButton" to="." method="_on_back_button_pressed"]
